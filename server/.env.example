# Copy to .env and fill in. Do not commit .env.
#
# watsonx.ai (refines fix strings after local scan) needs BOTH:
IBM_BOB_API_KEY=
# Project ID from IBM Cloud watsonx project (Resource list -> copy ID)
WATSONX_PROJECT_ID=
# Optional: region ML URL (default us-south)
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# Optional: model (default ibm/granite-3-8b-instruct)
# WATSONX_MODEL_ID=ibm/granite-3-8b-instruct
# WATSONX_API_VERSION=2024-05-31
